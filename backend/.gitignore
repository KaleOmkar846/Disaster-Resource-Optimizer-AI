# ── Dependencies ─────────────────────────────────────────────
node_modules/

# ── Environment variables ────────────────────────────────────
.env
.env.local
.env.*.local

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Uploaded / generated media files ────────────────────────
uploads/*
!uploads/.gitkeep
*.webm
*.mp3
*.wav
*.m4a

# ── ML model files (large binaries) ─────────────────────────
models/*.keras
models/*.h5
models/*.pt
models/*.onnx

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
